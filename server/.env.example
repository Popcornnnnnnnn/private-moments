HOST=127.0.0.1
PORT=3210
LOG_LEVEL=info
PRIVATE_MOMENTS_INITIAL_PASSWORD=change-me-before-use

# For local development. Prisma resolves this path relative to server/prisma/schema.prisma.
DATABASE_URL="file:./dev.db"

# Optional: use this to keep runtime test data out of the production macOS app data directory.
PRIVATE_MOMENTS_DATA_DIR="./data"
