generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model User {
  id           String   @id @default(uuid())
  passwordHash String   @map("password_hash")
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")

  devices Device[]

  @@map("users")
}

model Device {
  id        String    @id @default(uuid())
  userId    String    @map("user_id")
  name      String
  deviceKey String?   @map("device_key")
  tokenHash String    @unique @map("token_hash")
  platform  String
  lastSeenAt DateTime? @map("last_seen_at")
  revokedAt DateTime? @map("revoked_at")
  createdAt DateTime  @default(now()) @map("created_at")
  updatedAt DateTime  @updatedAt @map("updated_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdPosts Post[] @relation("CreatedPosts")
  updatedPosts Post[] @relation("UpdatedPosts")
  createdComments Comment[] @relation("CreatedComments")
  updatedComments Comment[] @relation("UpdatedComments")
  requestedAiSummaries AiSummary[] @relation("RequestedAiSummaries")
  syncOperations SyncOperation[]

  @@index([userId])
  @@index([revokedAt])
  @@unique([userId, platform, deviceKey])
  @@map("devices")
}

model Post {
  id                String    @id
  text              String
  isFavorite        Boolean   @default(false) @map("is_favorite")
  isPinned          Boolean   @default(false) @map("is_pinned")
  pinnedAt          DateTime? @map("pinned_at")
  aiTagProcessedAt  DateTime? @map("ai_tag_processed_at")
  tagsUserEditedAt  DateTime? @map("tags_user_edited_at")
  occurredAt        DateTime  @map("occurred_at")
  createdAt         DateTime  @default(now()) @map("created_at")
  updatedAt         DateTime  @updatedAt @map("updated_at")
  deletedAt         DateTime? @map("deleted_at")
  clientCreatedAt   DateTime? @map("client_created_at")
  clientUpdatedAt   DateTime? @map("client_updated_at")
  serverVersion     Int       @default(0) @map("server_version")
  createdByDeviceId String?   @map("created_by_device_id")
  updatedByDeviceId String?   @map("updated_by_device_id")

  createdByDevice Device? @relation("CreatedPosts", fields: [createdByDeviceId], references: [id], onDelete: SetNull)
  updatedByDevice Device? @relation("UpdatedPosts", fields: [updatedByDeviceId], references: [id], onDelete: SetNull)
  media           Media[]
  comments        Comment[]
  aiSummaries     AiSummary[]
  tags            PostTag[]

  @@index([occurredAt])
  @@index([deletedAt])
  @@index([isPinned, pinnedAt])
  @@index([serverVersion])
  @@map("posts")
}

model Review {
  id                      String    @id
  kind                    String
  rangeMode               String    @map("range_mode")
  rangeStart              DateTime  @map("range_start")
  rangeEnd                DateTime  @map("range_end")
  status                  String
  trigger                 String
  contentJson             String    @default("{}") @map("content_json")
  inputDigestHash         String?   @map("input_digest_hash")
  promptVersion           String    @map("prompt_version")
  provider                String?
  model                   String?
  language                String?
  errorCode               String?   @map("error_code")
  errorMessage            String?   @map("error_message")
  generatedAt             DateTime? @map("generated_at")
  regeneratedFromReviewId String?   @map("regenerated_from_review_id")
  publishedPostId         String?   @map("published_post_id")
  createdAt               DateTime  @default(now()) @map("created_at")
  updatedAt               DateTime  @updatedAt @map("updated_at")
  deletedAt               DateTime? @map("deleted_at")

  feedback ReviewFeedback[]

  @@index([kind])
  @@index([status])
  @@index([rangeStart, rangeEnd])
  @@index([createdAt])
  @@map("reviews")
}

model ReviewFeedback {
  id           String   @id @default(uuid())
  reviewId     String   @map("review_id")
  type         String
  note         String?
  metadataJson String   @default("{}") @map("metadata_json")
  createdAt    DateTime @default(now()) @map("created_at")

  review Review @relation(fields: [reviewId], references: [id], onDelete: Cascade)

  @@index([reviewId])
  @@index([type])
  @@map("review_feedback")
}

model ReviewMemory {
  id        String   @id @default(uuid())
  scope     String
  key       String
  valueJson String   @default("{}") @map("value_json")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@unique([scope, key])
  @@map("review_memory")
}

model ReviewSetting {
  id                      String   @id
  autoWeeklyEnabled       Boolean  @default(false) @map("auto_weekly_enabled")
  publishWeeklyToMoments  Boolean  @default(false) @map("publish_weekly_to_moments")
  lastAutoWeeklyDate      String?  @map("last_auto_weekly_date")
  createdAt               DateTime @default(now()) @map("created_at")
  updatedAt               DateTime @updatedAt @map("updated_at")

  @@map("review_settings")
}

model Tag {
  id                String    @id
  type              String
  name              String
  normalizedName    String    @unique @map("normalized_name")
  colorHex          String?   @map("color_hex")
  isDefault         Boolean   @default(false) @map("is_default")
  isArchived        Boolean   @default(false) @map("is_archived")
  aiUsableAsPrimary Boolean   @default(false) @map("ai_usable_as_primary")
  createdAt         DateTime  @default(now()) @map("created_at")
  updatedAt         DateTime  @updatedAt @map("updated_at")
  archivedAt        DateTime? @map("archived_at")

  aliases  TagAlias[]
  postTags PostTag[]
  checkInItems CheckInItem[]

  @@index([type])
  @@index([isArchived])
  @@map("tags")
}

model TagAlias {
  id              String    @id
  tagId           String    @map("tag_id")
  alias           String
  normalizedAlias String    @unique @map("normalized_alias")
  createdAt       DateTime  @default(now()) @map("created_at")
  deletedAt       DateTime? @map("deleted_at")

  tag Tag @relation(fields: [tagId], references: [id], onDelete: Cascade)

  @@index([tagId])
  @@map("tag_aliases")
}

model PostTag {
  id          String    @id
  postId      String    @map("post_id")
  tagId       String    @map("tag_id")
  role        String
  source      String
  confidence  Float?
  aiSummaryId String?   @map("ai_summary_id")
  createdAt   DateTime  @default(now()) @map("created_at")
  updatedAt   DateTime  @updatedAt @map("updated_at")
  deletedAt   DateTime? @map("deleted_at")

  post Post @relation(fields: [postId], references: [id], onDelete: Cascade)
  tag  Tag  @relation(fields: [tagId], references: [id], onDelete: Cascade)

  @@unique([postId, tagId])
  @@index([postId])
  @@index([tagId])
  @@index([role])
  @@map("post_tags")
}

model CheckInItem {
  id                    String    @id
  name                  String
  symbolName            String    @map("symbol_name")
  colorHex              String    @map("color_hex")
  recordMode            String    @map("record_mode")
  timeVisualization     String    @default("none") @map("time_visualization")
  activeWeekdaysJson    String    @map("active_weekdays_json")
  sortOrder             Int       @default(0) @map("sort_order")
  defaultShowInTimeline Boolean   @default(false) @map("default_show_in_timeline")
  tagId                 String?   @map("tag_id")
  createdAt             DateTime  @default(now()) @map("created_at")
  updatedAt             DateTime  @updatedAt @map("updated_at")
  archivedAt            DateTime? @map("archived_at")
  deletedAt             DateTime? @map("deleted_at")
  serverVersion         Int       @default(0) @map("server_version")

  tag     Tag?           @relation(fields: [tagId], references: [id], onDelete: SetNull)
  entries CheckInEntry[]

  @@index([sortOrder])
  @@index([archivedAt])
  @@index([deletedAt])
  @@index([tagId])
  @@index([serverVersion])
  @@map("checkin_items")
}

model CheckInEntry {
  id            String    @id
  itemId        String    @map("item_id")
  occurredAt    DateTime  @map("occurred_at")
  note          String    @default("")
  showInTimeline Boolean  @default(false) @map("show_in_timeline")
  clientCreatedAt DateTime? @map("client_created_at")
  clientUpdatedAt DateTime? @map("client_updated_at")
  createdAt     DateTime  @default(now()) @map("created_at")
  updatedAt     DateTime  @updatedAt @map("updated_at")
  deletedAt     DateTime? @map("deleted_at")
  serverVersion Int       @default(0) @map("server_version")

  item CheckInItem @relation(fields: [itemId], references: [id], onDelete: Cascade)
  media CheckInMedia[]

  @@index([itemId])
  @@index([occurredAt])
  @@index([deletedAt])
  @@index([serverVersion])
  @@map("checkin_entries")
}

model CheckInMedia {
  id                  String    @id
  entryId             String    @map("entry_id")
  kind                String
  status              String
  compressedPath      String?   @map("compressed_path")
  mimeType            String?   @map("mime_type")
  compressedSizeBytes Int?      @map("compressed_size_bytes")
  checksum            String?
  sortOrder           Int       @default(0) @map("sort_order")
  createdAt           DateTime  @default(now()) @map("created_at")
  updatedAt           DateTime  @updatedAt @map("updated_at")
  deletedAt           DateTime? @map("deleted_at")

  entry CheckInEntry @relation(fields: [entryId], references: [id], onDelete: Cascade)

  @@index([entryId])
  @@index([status])
  @@index([deletedAt])
  @@map("checkin_media")
}

model Media {
  id                  String    @id
  postId              String    @map("post_id")
  kind                String
  status              String
  compressedPath      String?   @map("compressed_path")
  originalPath        String?   @map("original_path")
  thumbnailPath       String?   @map("thumbnail_path")
  mimeType            String?   @map("mime_type")
  durationSeconds     Float?    @map("duration_seconds")
  transcriptionText   String?   @map("transcription_text")
  originalPreserved   Boolean   @default(false) @map("original_preserved")
  width               Int?
  height              Int?
  compressedSizeBytes Int?      @map("compressed_size_bytes")
  originalSizeBytes   Int?      @map("original_size_bytes")
  checksum            String?
  sortOrder           Int       @default(0) @map("sort_order")
  createdAt           DateTime  @default(now()) @map("created_at")
  updatedAt           DateTime  @updatedAt @map("updated_at")
  deletedAt           DateTime? @map("deleted_at")

  post Post @relation(fields: [postId], references: [id], onDelete: Cascade)
  aiSummaries AiSummary[]

  @@index([postId])
  @@index([status])
  @@index([deletedAt])
  @@map("media")
}

model AiSummary {
  id                    String    @id
  postId                String    @map("post_id")
  mediaId               String    @unique @map("media_id")
  status                String
  format                String?
  language              String?
  overview              String?
  keyPointsJson         String    @default("[]") @map("key_points_json")
  sectionsJson          String    @default("[]") @map("sections_json")
  summaryText           String?   @map("summary_text")
  documentTitle         String?   @map("document_title")
  oneLiner              String?   @map("one_liner")
  documentBlocksJson    String    @default("[]") @map("document_blocks_json")
  inputTranscriptHash   String?   @map("input_transcript_hash")
  inputTranscriptLength Int?      @map("input_transcript_length")
  inputDurationSeconds  Float?    @map("input_duration_seconds")
  promptVersion         String    @map("prompt_version")
  provider              String?
  model                 String?
  errorCode             String?   @map("error_code")
  errorMessage          String?   @map("error_message")
  requestedByDeviceId   String?   @map("requested_by_device_id")
  createdAt             DateTime  @default(now()) @map("created_at")
  updatedAt             DateTime  @updatedAt @map("updated_at")
  deletedAt             DateTime? @map("deleted_at")

  post Post @relation(fields: [postId], references: [id], onDelete: Cascade)
  media Media @relation(fields: [mediaId], references: [id], onDelete: Cascade)
  requestedByDevice Device? @relation("RequestedAiSummaries", fields: [requestedByDeviceId], references: [id], onDelete: SetNull)

  @@index([postId])
  @@index([status])
  @@index([deletedAt])
  @@map("ai_summaries")
}

model AiUsageEvent {
  id                    String   @id @default(uuid())
  feature               String
  subjectType           String   @map("subject_type")
  subjectId             String?  @map("subject_id")
  provider              String?
  model                 String?
  promptVersion         String?  @map("prompt_version")
  status                String
  inputChars            Int?     @map("input_chars")
  outputChars           Int?     @map("output_chars")
  inputTokens           Int?     @map("input_tokens")
  outputTokens          Int?     @map("output_tokens")
  totalTokens           Int?     @map("total_tokens")
  cachedInputTokens     Int?     @map("cached_input_tokens")
  estimatedInputTokens  Int?     @map("estimated_input_tokens")
  estimatedOutputTokens Int?     @map("estimated_output_tokens")
  estimatedTotalTokens  Int?     @map("estimated_total_tokens")
  durationMs            Int?     @map("duration_ms")
  errorCode             String?  @map("error_code")
  createdAt             DateTime @default(now()) @map("created_at")

  @@index([createdAt])
  @@index([feature, createdAt])
  @@index([status, createdAt])
  @@map("ai_usage_events")
}

model Comment {
  id                String    @id
  postId            String    @map("post_id")
  text              String
  createdAt         DateTime  @default(now()) @map("created_at")
  updatedAt         DateTime  @updatedAt @map("updated_at")
  deletedAt         DateTime? @map("deleted_at")
  clientCreatedAt   DateTime? @map("client_created_at")
  clientUpdatedAt   DateTime? @map("client_updated_at")
  serverVersion     Int       @default(0) @map("server_version")
  createdByDeviceId String?   @map("created_by_device_id")
  updatedByDeviceId String?   @map("updated_by_device_id")

  post Post @relation(fields: [postId], references: [id], onDelete: Cascade)
  createdByDevice Device? @relation("CreatedComments", fields: [createdByDeviceId], references: [id], onDelete: SetNull)
  updatedByDevice Device? @relation("UpdatedComments", fields: [updatedByDeviceId], references: [id], onDelete: SetNull)

  @@index([postId])
  @@index([deletedAt])
  @@index([serverVersion])
  @@map("comments")
}

model SyncOperation {
  id              String    @id @default(uuid())
  opId            String    @map("op_id")
  deviceId        String    @map("device_id")
  type            String
  entityType      String    @map("entity_type")
  entityId        String    @map("entity_id")
  payloadJson     String    @map("payload_json")
  receivedAt      DateTime  @default(now()) @map("received_at")
  appliedAt       DateTime? @map("applied_at")
  rejectedAt      DateTime? @map("rejected_at")
  rejectionReason String?   @map("rejection_reason")

  device Device @relation(fields: [deviceId], references: [id], onDelete: Cascade)

  @@unique([deviceId, opId])
  @@index([entityType, entityId])
  @@map("sync_operations")
}

model ServerChange {
  version    Int      @id @default(autoincrement())
  entityType String   @map("entity_type")
  entityId   String   @map("entity_id")
  changeType String   @map("change_type")
  payloadJson String  @map("payload_json")
  createdAt  DateTime @default(now()) @map("created_at")

  @@index([entityType, entityId])
  @@map("server_changes")
}

model MaintenanceJob {
  id           String    @id @default(uuid())
  type         String
  status       String
  stage        String?
  progress     Int       @default(0)
  metadataJson String    @default("{}") @map("metadata_json")
  artifactPath String?   @map("artifact_path")
  errorCode    String?   @map("error_code")
  errorMessage String?   @map("error_message")
  createdAt    DateTime  @default(now()) @map("created_at")
  startedAt    DateTime? @map("started_at")
  finishedAt   DateTime? @map("finished_at")

  @@index([type])
  @@index([status])
  @@index([createdAt])
  @@map("maintenance_jobs")
}
