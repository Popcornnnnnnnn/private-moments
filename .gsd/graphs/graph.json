    {
      "id": "decision:M001:1",
      "label": "Keep date navigation in the existing toolbar calendar menu, with month submenus, direct Jump to Month actions, and day buttons rather than adding a calendar/archive surface.",
      "type": "decision",
      "description": "Source: S01-SUMMARY.md/Key decisions",
      "confidence": "EXTRACTED",
      "sourceFile": "milestones/M001/M001-LEARNINGS.md"
    },
    {
      "id": "decision:M001:2",
      "label": "Keep date-jump grouping pure and caller-driven so TimelineView passes filteredItems and the model never queries broader persistence/media state.",
      "type": "decision",
      "description": "Source: S01-SUMMARY.md/Key decisions",
      "confidence": "EXTRACTED",
      "sourceFile": "milestones/M001/M001-LEARNINGS.md"
    },
    {
      "id": "decision:M001:3",
      "label": "Keep list continuation as local plain-string editing with no Markdown/rich-text semantics, persistence/schema changes, server changes, sync changes, telemetry, or logging.",
      "type": "decision",
      "description": "Source: S02-SUMMARY.md/Key decisions",
      "confidence": "EXTRACTED",
      "sourceFile": "milestones/M001/M001-LEARNINGS.md"
    },
    {
      "id": "decision:M001:4",
      "label": "Reuse one shared PlainTextListEditor component for both Composer and Edit Moment instead of forking per-screen behavior.",
      "type": "decision",
      "description": "Source: S02-SUMMARY.md/Key decisions",
      "confidence": "EXTRACTED",
      "sourceFile": "milestones/M001/M001-LEARNINGS.md"
    },
    {
      "id": "decision:M001:5",
      "label": "Maintain a root project.yml mirror to satisfy root-level automation while preserving ios/project.yml for the documented iOS workflow.",
      "type": "decision",
      "description": "Source: S01-SUMMARY.md/Deviations",
      "confidence": "EXTRACTED",
      "sourceFile": "milestones/M001/M001-LEARNINGS.md"
    },
    {
      "id": "decision:M001:6",
      "label": "Auto verification may run XcodeGen from the repository root even when the human workflow says `cd ios`; either keep the root spec mirror synchronized or standardize automation around `xcodegen generate --spec ios/project.yml`.",
      "type": "decision",
      "description": "Source: S01-SUMMARY.md/Deviations",
      "confidence": "EXTRACTED",
      "sourceFile": "milestones/M001/M001-LEARNINGS.md"
    },
    {
      "id": "decision:M001:7",
      "label": "Simulator-name verification failures can be environmental rather than code failures; if the device type and runtime exist, create the missing simulator and rerun the planned xcodebuild destination unchanged.",
      "type": "decision",
      "description": "Source: S02-SUMMARY.md/Deviations",
      "confidence": "EXTRACTED",
      "sourceFile": "milestones/M001/M001-LEARNINGS.md"
    },
    {
      "id": "decision:M001:8",
      "label": "Manual tactile UAT is still needed for nested menu ergonomics, scroll feel, editor cursor behavior, and saved plain-text display; automated tests/builds prove contracts and integration but not final touch feel.",
      "type": "decision",
      "description": "Source: M001-VALIDATION.md/Verification Class Compliance",
      "confidence": "EXTRACTED",
      "sourceFile": "milestones/M001/M001-LEARNINGS.md"
    },
    {
      "id": "decision:M001:9",
      "label": "Moment text is private, so diagnostics for text-entry behavior should be deterministic tests and build output rather than runtime logging or telemetry of typed content.",
      "type": "decision",
      "description": "Source: S02-SUMMARY.md/Observability/diagnostics",
      "confidence": "EXTRACTED",
      "sourceFile": "milestones/M001/M001-LEARNINGS.md"
    },
    {
      "id": "decision:M001:10",
      "label": "Visible-only UI navigation models should accept already-filtered view items from the caller instead of querying persistence, preserving search/filter semantics and avoiding database/archive coupling.",
      "type": "decision",
      "description": "Source: S01-SUMMARY.md/Patterns established",
      "confidence": "EXTRACTED",
      "sourceFile": "milestones/M001/M001-LEARNINGS.md"
    },
    {
      "id": "decision:M001:11",
      "label": "Date labels for timeline navigation belong in MomentDateFormatter and must remain count/statistics-free.",
      "type": "decision",
      "description": "Source: S01-SUMMARY.md/Patterns established",
      "confidence": "EXTRACTED",
      "sourceFile": "milestones/M001/M001-LEARNINGS.md"
    },
    {
      "id": "decision:M001:12",
      "label": "SwiftUI scroll targets for mixed section/row navigation can use a neutral target ID request with section anchor IDs and row `.id(item.id)` values.",
      "type": "decision",
      "description": "Source: S01-SUMMARY.md/Patterns established",
      "confidence": "EXTRACTED",
      "sourceFile": "milestones/M001/M001-LEARNINGS.md"
    },
    {
      "id": "decision:M001:13",
      "label": "For UIKit text-editing helpers, isolate string/range transformation in a pure NSRange/UTF-16 helper and test Unicode boundaries before wiring UI.",
      "type": "decision",
      "description": "Source: S02-SUMMARY.md/Patterns established",
      "confidence": "EXTRACTED",
      "sourceFile": "milestones/M001/M001-LEARNINGS.md"
    },
    {
      "id": "decision:M001:14",
      "label": "For lightweight input polish, share one plain editor component across Composer/Edit surfaces and preserve the existing plain Binding<String> save/draft path.",
      "type": "decision",
